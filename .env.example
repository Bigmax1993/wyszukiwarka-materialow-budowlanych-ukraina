# Skopiuj do .env (lokalnie) lub ustaw jako GitHub Secrets / zmienne w Task Scheduler.
# NIE commituj .env z prawdziwymi hasłami.

# --- Harmonogram wysyłki (dowolna godzina startu, np. 2:00 w nocy) ---
# Wyłącza okno 8–18 — zalecane dla GitHub Actions i nocnego cron:
DISABLE_SEND_WINDOW=1
# Alternatywnie: cała doba bez wyłączania flagi:
# SEND_WINDOW_START_HOUR=0
# SEND_WINDOW_END_HOUR=24
# Strefa dla okna (gdy DISABLE_SEND_WINDOW=0):
SCRAPER_TIMEZONE=Europe/Warsaw

# --- Poczta (yagmail → Gmail lub SMTP) ---
MAIL_USER=twoj@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_SENDER_NAME=Свінчак Максим
# Opcjonalnie — kontekst w mailach UA (podpis, treść zapytania):
# INQUIRY_COMPANY_NAME=ТОВ «Ваша компанія»
# INQUIRY_PHONE=+380977091141
# (numery +49 są ignorowane — wtedy używany jest domyślny UA powyżej)
# INQUIRY_WEBSITE=https://example.ua
# Dla Gmail nie trzeba SMTP_HOST — yagmail łączy się automatycznie.
# Dla home.pl / inny SMTP:
# SMTP_HOST=serwer.home.pl
# SMTP_PORT=465
# SMTP_SSL=1
# IMAP_HOST=serwer.home.pl
# Opcjonalna widoczna kopia:
# MAIL_CC=

# --- API ---
SERPER_API_KEY=
ANTHROPIC_API_KEY=

# Ścieżka do bibliotek Kanbud (polish_text.py, scraper_env)
KANBUD_PROJECT_ROOT=C:\Users\kanbu\Documents\piasek Gdansk

# --- Wyniki UA materiały (kampania produkcyjna) ---
# Utwórz folder na Drive i ustaw lokalną ścieżkę synchronizacji:
# KANBUD_DATA_DIR=G:\Mój dysk\UA Materialy Budowlane Wyniki
# GitHub Secret: GDRIVE_FOLDER_ID_UA=

# --- Wyniki PL materiały ---
# https://drive.google.com/drive/folders/1O15CdN0TH8rx74sPP5C1GuYSweX81IGw
# KANBUD_DATA_DIR=G:\Mój dysk\PL Materialy Budowlane Wyniki
# GitHub Secret: GDRIVE_FOLDER_ID_PL=1O15CdN0TH8rx74sPP5C1GuYSweX81IGw

# --- DE GU (legacy — wyłączony z produkcji) ---
# https://drive.google.com/drive/folders/1tP8oUi72t4EHDbE9GnHFdvfNtNsJe4xf
# KANBUD_GOOGLE_DRIVE_GU_PATH=G:\Mój dysk\GU Bauunternehmen Wyniki
# MFG_EMAIL_ATTACHMENT_PATH=C:\Users\kanbu\Documents\Prezentacja\MFG_Moderner Fliesenboden.pptx

# Google Drive (lokalnie — pliki w secrets/, NIE commituj do git):
# scripts\map_gdrive_secrets.ps1
# GDRIVE_SERVICE_ACCOUNT_FILE=secrets/gdrive-service-account.json
# OAuth Desktop: secrets/gdrive-oauth-client.json + python scripts/gdrive_oauth_setup.py
